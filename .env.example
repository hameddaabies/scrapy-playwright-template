# Optional proxy (leave blank to scrape without a proxy).
# Supported schemes: http://, https://, socks5://
PROXY_URL=

# Comma-separated user-agent strings, rotated per-request.
# Leave blank to use the built-in defaults in middlewares.py.
USER_AGENTS=

# Raw Cookie header value (e.g. "sessionid=abc; csrftoken=xyz") seeded onto
# every outbound request when CookieHeaderMiddleware is enabled in settings.py.
# Copy from a logged-in browser session via DevTools → Network → Request Headers.
COOKIE_HEADER=
